public class Qarakusi {
    private double koxm;

    public Qarakusi(double komm){
        System.out.println("Qarakusi classi 1 parametrov kanch:");
        koxm = komm;
    }
    public void talkox(double tiv){
        koxm = tiv;
    }
    public double stanalkox(){
        return koxm;
    }

    public double area(double tiv){
